# App #2 (claims backend) configuration. Copy to .env and fill in. NEVER commit .env.
# Secrets are read from the environment only — nothing is baked into source.

# --- Postgres (docker-compose + backend) ---
CLAIMS_DB_NAME=claims
CLAIMS_DB_USER=claims
CLAIMS_DB_PASSWORD=change-me-local
CLAIMS_DB_URL=jdbc:postgresql://localhost:5433/claims

# --- platform-stack auth ---
# jwt-secret MUST be >= 32 bytes or the backend fails to start. Generate one with:
#   openssl rand -base64 48
CLAIMS_JWT_SECRET=
# Optional: only used by the (unexposed) client-credentials token endpoint. Leave blank.
CLAIMS_AUTH_CLIENT_SECRET=

# --- Social sign-in (optional; blank disables the provider) ---
# Google OAuth *Web* client id (used as the Android Credential Manager serverClientId too).
GOOGLE_OAUTH_CLIENT_ID=
# GitHub OAuth App credentials + redirect (custom scheme used by the Android app).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
